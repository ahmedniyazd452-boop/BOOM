<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Travel Explorer</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0; padding: 0;
      background: #f4f4f4;
    }
    header {
      background: #3498db;
      color: white;
      padding: 20px;
      text-align: center;
    }
    nav {
      display: flex;
      justify-content: center;
      background: #2980b9;
    }
    nav a {
      color: white;
      padding: 14px 20px;
      text-decoration: none;
    }
    nav a:hover {
      background: #1abc9c;
    }
    .hero {
      background: url('travel.jpg') no-repeat center center/cover;
      height: 400px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 2.5em;
      font-weight: bold;
      text-shadow: 2px 2px 5px #000;
    }
    .container {
      padding: 20px;
    }
    .card {
      background: white;
      padding: 20px;
      margin: 10px;
      border-radius: 8px;
      box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    }
    footer {
      background: #3498db;
      color: white;
      text-align: center;
      padding: 10px;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <header>
    <h1>Travel Explorer</h1>
    <p>Discover Your Next Adventure</p>
  </header>

  <nav>
    <a href="#">Home</a>
    <a href="#">Destinations</a>
    <a href="#">Tours</a>
    <a href="#">Contact</a>
  </nav>

  <div class="hero">Explore the India</div>

 
</div><div class="container">
  <!-- Goa -->
  <div class="card" onclick="goToPage('goa.html')" style="cursor:pointer;">
    <h2>Goa, India</h2>
    <p>Famous for its beaches, nightlife, and Portuguese heritage.</p>
  </div>

  <!-- Kerala -->
  <div class="card" onclick="goToPage('kerala.html')" style="cursor:pointer;">
    <h2>Kerala, India</h2>
    <p>Explore serene backwaters, lush greenery, and Ayurvedic retreats.</p>
  </div>

  <!-- Jaipur -->
  <div class="card" onclick="goToPage('jaipur.html')" style="cursor:pointer;">
    <h2>Jaipur, India</h2>
    <p>The Pink City with palaces, forts, and vibrant bazaars.</p>
  </div>

  <!-- Ladakh -->
  <div class="card" onclick="goToPage('ladakh.html')" style="cursor:pointer;">
    <h2>Ladakh, India</h2>
    <p>Adventure in the Himalayas with breathtaking landscapes.</p>
  </div>

  <!-- Agra -->
  <div class="card" onclick="goToPage('agra.html')" style="cursor:pointer;">
    <h2>Agra, India</h2>
    <p>Home to the iconic Taj Mahal, a symbol of love.</p>
  </div>
</div>

<script>
  // Redirect function
  function goToPage(page) {
    window.location.href = page;
  }
</script>

<!--Booking Form-->
<div class="container">
  <h2>Book Your Trip</h2>
  <form style="background:white; padding:20px; border-radius:8px; box-shadow:0 2px 5px rgba(0,0,0,0.1);">
    <label>Destination:</label><br>
    <input type="text" name="destination" placeholder="Enter destination" required><br><br>

    <label>Travel Date:</label><br>
    <input type="date" name="date" required><br><br>

    <label>Number of Travelers:</label><br>
    <input type="number" name="travelers" min="1" required><br><br>

    <label>Email:</label><br>
    <input type="email" name="email" placeholder="Enter your email" required><br><br>

    <button type="submit" style="background:#3498db; color:white; padding:10px 20px; border:none; border-radius:5px;">Book Now</button>
  </form>
</div>

<!--Galary of Destinations-->
<div class="container">
  <h2>Destination Gallery</h2>
  <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(250px,1fr)); gap:15px;">
    <img src="taj mahal.jpg" alt="Taj Mahal" style="width:100%; border-radius:8px;">
    <img src="kerala backwaters.jpg" alt="Kerala Backwaters" style="width:100%; border-radius:8px;">
    <img src="goa beach.jpg" alt="Goa Beach" style="width:100%; border-radius:8px;">
    <img src="ladakh mountains.jpg" alt="Ladakh Mountains" style="width:100%; border-radius:8px;">
    <img src="jaipur palace.png" alt="Jaipur Palace" style="width:100%; border-radius:8px;">
  </div>
</div>
<!-- Flight Booking Section -->
<section style="background:#f9f9f9; padding:30px; border-bottom:2px solid #ddd;">
  <h2 style="text-align:center; color:#3498db;">Book Your Flight</h2>
  <form style="max-width:800px; margin:0 auto; background:white; padding:20px; border-radius:10px; box-shadow:0 2px 5px rgba(0,0,0,0.1);">
    
    <!-- Trip Type -->
    <label>Trip Type:</label><br>
    <select style="width:100%; padding:10px; margin:5px 0; border-radius:5px;">
      <option>One Way</option>
      <option>Round Trip</option>
    </select><br><br>

    <!-- Departure & Destination -->
    <div style="display:flex; gap:10px;">
      <input type="text" placeholder="From (City/Airport)" style="flex:1; padding:10px; border-radius:5px; border:1px solid #ccc;" required>
      <input type="text" placeholder="To (City/Airport)" style="flex:1; padding:10px; border-radius:5px; border:1px solid #ccc;" required>
    </div><br>

    <!-- Dates -->
    <div style="display:flex; gap:10px;">
      <input type="date" placeholder="Departure Date" style="flex:1; padding:10px; border-radius:5px; border:1px solid #ccc;" required>
      <input type="date" placeholder="Return Date (optional)" style="flex:1; padding:10px; border-radius:5px; border:1px solid #ccc;">
    </div><br>

    <!-- Travellers & Class -->
    <div style="display:flex; gap:10px;">
      <input type="number" min="1" placeholder="Travellers" style="flex:1; padding:10px; border-radius:5px; border:1px solid #ccc;" required>
      <select style="flex:1; padding:10px; border-radius:5px;">
        <option>Economy</option>
        <option>Premium Economy</option>
        <option>Business</option>
        <option>First Class</option>
      </select>
    </div><br>

    <!-- Special Fares -->
    <label>Special Fares:</label><br>
    <select style="width:100%; padding:10px; margin:5px 0; border-radius:5px;">
      <option>Regular</option>
      <option>Student</option>
      <option>Armed Forces</option>
      <option>Senior Citizen</option>
      <option>Doctor & Nurses</option>
    </select><br><br>

    <!-- Search Button -->
    <button type="submit" style="width:100%; background:#e67e22; color:white; padding:15px; font-size:16px; border:none; border-radius:5px; cursor:pointer;">
      SEARCH
    </button>
  </form>
</section>
  <footer>
    <p>&copy; 2026 Travel Explorer | Designed by BOOM</p>
  </footer>

  <script>
    // Example: Simple greeting popup
    window.onload = () => {
      alert("Welcome to Travel Explorer!");
    };
  </script>
</body>
</html>
